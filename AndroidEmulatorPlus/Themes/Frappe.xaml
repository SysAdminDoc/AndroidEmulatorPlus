<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Frappe palette (medium-dark) -->
    <Color x:Key="BaseColor">#FF303446</Color>
    <Color x:Key="MantleColor">#FF292C3C</Color>
    <Color x:Key="CrustColor">#FF232634</Color>
    <Color x:Key="SurfaceColor">#FF414559</Color>
    <Color x:Key="Surface1Color">#FF51576D</Color>
    <Color x:Key="OverlayColor">#FF737994</Color>
    <Color x:Key="TextColor">#FFC6D0F5</Color>
    <Color x:Key="SubtextColor">#FFA5ADCE</Color>
    <Color x:Key="BlueColor">#FF8CAAEE</Color>
    <Color x:Key="LavenderColor">#FFBABBF1</Color>
    <Color x:Key="GreenColor">#FFA6D189</Color>
    <Color x:Key="YellowColor">#FFE5C890</Color>
    <Color x:Key="RedColor">#FFE78284</Color>
    <Color x:Key="MauveColor">#FFCA9EE6</Color>
    <Color x:Key="TealColor">#FF81C8BE</Color>
    <Color x:Key="PeachColor">#FFEF9F76</Color>

    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}"/>
    <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource MantleColor}"/>
    <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource CrustColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource BlueColor}"/>
    <SolidColorBrush x:Key="LavenderBrush" Color="{StaticResource LavenderColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource MauveColor}"/>
    <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}"/>
    <SolidColorBrush x:Key="PeachBrush" Color="{StaticResource PeachColor}"/>

</ResourceDictionary>
