<Application x:Class="AndroidEmulatorPlus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Palette + styles are merged programmatically in App.OnStartup so the
                 theme choice can be loaded from settings.json before any view binds. -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
