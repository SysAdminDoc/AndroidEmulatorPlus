<Window x:Class="AndroidEmulatorPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AndroidEmulatorPlus.Views"
        xmlns:vm="clr-namespace:AndroidEmulatorPlus.ViewModels"
        Title="AndroidEmulatorPlus v0.2.7"
        Width="1280" Height="820"
        MinWidth="980" MinHeight="640"
        Icon="Assets/aep.ico"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" MinHeight="56" Background="{DynamicResource MantleBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AndroidEmulatorPlus" FontWeight="SemiBold" FontSize="16"
                               Foreground="{DynamicResource LavenderBrush}"/>
                    <TextBlock Text="v0.2.7" Margin="8,1,0,0" Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusPill}" Margin="4" ToolTip="{Binding SdkDetailText}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SDK" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SdkStatusText}" Margin="7,0,0,0" Foreground="{DynamicResource SubtextBrush}" FontSize="12"
                                       MaxWidth="96" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusPill}" Margin="4" Background="{DynamicResource SurfaceBrush}" ToolTip="{Binding PhoneDetailText}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Phone" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PhoneStatusText}" Margin="7,0,0,0" Foreground="{DynamicResource SubtextBrush}" FontSize="12"
                                       MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusPill}" Margin="4" Background="{DynamicResource SurfaceBrush}" ToolTip="{Binding EmulatorDetailText}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Emulator" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding EmulatorStatusText}" Margin="7,0,0,0" Foreground="{DynamicResource SubtextBrush}" FontSize="12"
                                       MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SmallButton}" Margin="10,8,0,8"
                            Content="Screenshot"
                            AutomationProperties.Name="Capture emulator screenshot"
                            Command="{Binding ScreenshotCommand}"
                            IsEnabled="{Binding HasEmulatorAttached}"
                            Visibility="{Binding HasEmulatorAttached, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                            ToolTip="Capture a PNG from the attached emulator"/>
                    <Button Style="{StaticResource SmallButton}" Margin="8,8,0,8"
                            Content="{Binding RecordButtonText}"
                            AutomationProperties.Name="Record emulator screen"
                            Command="{Binding RecordCommand}"
                            IsEnabled="{Binding HasEmulatorAttached}"
                            Visibility="{Binding HasEmulatorAttached, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                            ToolTip="Start / stop screenrecord on the attached emulator (capped at 3 min by Android)"/>
                    <Button Style="{StaticResource SmallButton}" Margin="8,8,0,8"
                            Content="Mirror"
                            AutomationProperties.Name="Mirror emulator with scrcpy"
                            Command="{Binding LaunchScrcpyCommand}"
                            IsEnabled="{Binding HasEmulatorAttached}"
                            Visibility="{Binding HasEmulatorAttached, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                            ToolTip="Launch external scrcpy.exe against the attached emulator (winget install Genymobile.scrcpy)"/>
                    <Button Style="{StaticResource SmallButton}" Margin="8,8,0,8"
                            Content="Settings"
                            AutomationProperties.Name="Open settings"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Theme, paths, network proxy - persists to %LOCALAPPDATA%\AndroidEmulatorPlus\settings.json"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="216"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="{DynamicResource MantleBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,14">
                    <TextBlock Text="WORKFLOW" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource OverlayBrush}" Margin="20,4,0,10"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Install / SDK"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Install, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Install"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="AVDs"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Avd, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Avd"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Root"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Root, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Root"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Migrate from Phone"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Migrate, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Migrate"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Apps / Debloat"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Apps, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Apps"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Configure"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Config, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Config"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Logcat"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Logcat, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Logcat"/>
                    <RadioButton Style="{StaticResource SidebarButton}" Content="Console"
                                 IsChecked="{Binding ActiveSection, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Console, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Console"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1" Background="{DynamicResource BaseBrush}">
                <views:InstallView DataContext="{Binding InstallVm}"
                                   Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Install}"/>
                <views:AvdView DataContext="{Binding AvdVm}"
                               Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Avd}"/>
                <views:RootView DataContext="{Binding RootVm}"
                                Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Root}"/>
                <views:MigrateView DataContext="{Binding MigrateVm}"
                                   Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Migrate}"/>
                <views:AppsView DataContext="{Binding AppsVm}"
                                Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Apps}"/>
                <views:ConfigView DataContext="{Binding ConfigVm}"
                                  Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Config}"/>
                <views:LogcatView DataContext="{Binding LogcatVm}"
                                  Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Logcat}"/>
                <views:ConsoleView DataContext="{Binding ConsoleVm}"
                                   Visibility="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static views:VisibleIfEqualConverter.Instance}, ConverterParameter=Console}"/>
            </Grid>
        </Grid>

        <!-- Log panel -->
        <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                      Background="{DynamicResource SurfaceBrush}" />
        <Border Grid.Row="2" Background="{DynamicResource MantleBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Activity log" FontWeight="SemiBold" Foreground="{DynamicResource MauveBrush}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="LogFilterBox"
                             Margin="12,0,8,0" Padding="4,2" FontSize="11"
                             FontFamily="Cascadia Mono, Consolas, monospace"
                             AutomationProperties.Name="Filter activity log"
                             TextChanged="LogFilter_TextChanged"/>
                    <Button Grid.Column="2" Content="Clear log" Style="{StaticResource SmallButton}" Click="ClearLog_Click" AutomationProperties.Name="Clear activity log"/>
                </Grid>
                <Border Grid.Row="1" Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,7,0,0">
                    <ItemsControl ItemsSource="{Binding Log.Entries}" x:Name="LogList"
                                    AutomationProperties.Name="Activity log"
                                    AutomationProperties.LiveSetting="Polite">
                        <ItemsControl.Template>
                            <ControlTemplate>
                                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                                           TextWrapping="NoWrap" Margin="0,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                    <Setter Property="Foreground" Value="{DynamicResource GreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{DynamicResource YellowBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="{DynamicResource RedBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Detail">
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
