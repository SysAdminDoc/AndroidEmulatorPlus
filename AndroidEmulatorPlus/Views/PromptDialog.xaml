<Window x:Class="AndroidEmulatorPlus.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt"
        Width="480" SizeToContent="Height"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="24,20">
        <TextBlock x:Name="HeaderText"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource LavenderBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>
        <TextBlock x:Name="BodyText"
                   Foreground="{DynamicResource SubtextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>
        <TextBox x:Name="InputBox" KeyDown="InputBox_KeyDown"/>
        <TextBlock x:Name="ErrorText"
                   Foreground="{DynamicResource RedBrush}"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Margin="0,6,0,0"
                   Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="OkButton" Content="OK" Style="{StaticResource PrimaryButton}"
                    Click="OkButton_Click" Margin="10,0,0,0" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
