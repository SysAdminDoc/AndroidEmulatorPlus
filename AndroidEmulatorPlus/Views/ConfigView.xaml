<UserControl x:Class="AndroidEmulatorPlus.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Configure"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Edit the AVD's hardware profile and disk size. Disk grow requires a wipe to expand the partition's filesystem.
            </TextBlock>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Target AVD"/>
                    <ComboBox ItemsSource="{Binding Avds}" SelectedItem="{Binding Selected}" DisplayMemberPath="Name"
                              AutomationProperties.Name="Target AVD"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hardware"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="RAM (MB)" VerticalAlignment="Center" Style="{StaticResource FieldLabel}"/>
                        <Slider Grid.Column="1" Minimum="1024" Maximum="16384" SmallChange="256" LargeChange="1024" Value="{Binding RamMb}" VerticalAlignment="Center"
                                AutomationProperties.Name="RAM in megabytes"/>
                        <TextBlock Grid.Column="2" Text="{Binding RamMb}" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Text="CPU cores" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="16" Value="{Binding Cores}" VerticalAlignment="Center" Margin="0,8,0,0"
                                AutomationProperties.Name="CPU cores"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Cores}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="Disk (GB)" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="8" Maximum="256" Value="{Binding DiskGb}" VerticalAlignment="Center" Margin="0,8,0,0"
                                AutomationProperties.Name="Disk size in gigabytes"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DiskGb}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="3" Text="Width" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding ScreenW}" Margin="0,8,0,0"
                                  AutomationProperties.Name="Screen width"/>
                        <TextBlock Grid.Row="4" Text="Height" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <TextBox  Grid.Row="4" Grid.Column="1" Text="{Binding ScreenH}" Margin="0,8,0,0"
                                  AutomationProperties.Name="Screen height"/>
                        <TextBlock Grid.Row="5" Text="DPI" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <TextBox  Grid.Row="5" Grid.Column="1" Text="{Binding Dpi}" Margin="0,8,0,0"
                                  AutomationProperties.Name="Screen DPI"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Screen preset"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Device" VerticalAlignment="Center" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ScreenPresets}" SelectedItem="{Binding ScreenPreset}"
                                  AutomationProperties.Name="Screen preset"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" Margin="0,6,0,0">
                        Picking a preset updates Width, Height, and DPI above.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="GPU mode"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="hw.gpu.mode" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" FontFamily="Cascadia Mono"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding GpuModes}" SelectedItem="{Binding GpuMode}"
                                  AutomationProperties.Name="GPU mode"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">host</Run>: native GPU passthrough — fastest on a real desktop.
                        <Run FontWeight="SemiBold">swiftshader_indirect</Run>: software rasterizer — use inside a VM or over RDP.
                        <Run FontWeight="SemiBold">angle_indirect</Run>: ANGLE → DirectX — works around buggy GPU drivers.
                        <Run FontWeight="SemiBold">guest</Run>: render inside the emulated GPU.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Boot"/>
                    <CheckBox Content="Fast boot (use saved snapshot)" IsChecked="{Binding FastBoot}"
                              AutomationProperties.Name="Fast boot using saved snapshot"/>
                    <CheckBox Content="Cold boot always" IsChecked="{Binding ColdBootAlways}"
                              AutomationProperties.Name="Cold boot always"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Apply"/>
                    <WrapPanel Margin="0,0,-8,-8">
                        <Button Content="Save config" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyCommand}" Margin="0,0,8,8"
                                AutomationProperties.Name="Save configuration"/>
                        <Button Content="Resize disk file" Style="{StaticResource FlatButton}" Command="{Binding ResizeDiskCommand}" CommandParameter="resize" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Resize disk file"/>
                        <Button Content="Resize and wipe data" Style="{StaticResource DangerButton}" Command="{Binding ResizeDiskCommand}" CommandParameter="wipe" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Resize disk and wipe data"/>
                    </WrapPanel>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap">
                        Resize-only grows the qcow2 file but Android's ext4 won't auto-expand — apps still see the old partition size.
                        Resize + Wipe Data deletes overlays so the partition recreates at the new size on next boot.
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Emulator performance"/>
                        <Button Grid.Column="1" Content="Refresh" Style="{StaticResource FlatButton}" Padding="10,4" MinHeight="0"
                                Command="{Binding RefreshPerfCommand}" AutomationProperties.Name="Refresh emulator performance"/>
                    </Grid>
                    <Border Background="{DynamicResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0"
                            Visibility="{Binding HasPerfData, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding PerfText}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}" TextWrapping="NoWrap"/>
                    </Border>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
                        CPU and memory stats from the attached emulator via adb shell.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
