<Window x:Class="AndroidEmulatorPlus.Views.MagiskModulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Magisk Modules"
        Width="720" Height="540"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource LavenderBrush}" Text="Magisk modules"/>
            <TextBlock x:Name="TargetText" Foreground="{StaticResource SubtextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,6"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Curated catalog"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Open homepage" Style="{StaticResource FlatButton}" Click="OpenHomepage_Click" Padding="10,4" MinHeight="0"/>
                        <Button Content="Install from zip…" Style="{StaticResource FlatButton}" Click="InstallFromZip_Click" Margin="8,0,0,0" Padding="10,4" MinHeight="0"/>
                        <Button Content="Install selected" Style="{StaticResource PrimaryButton}" Click="InstallCatalog_Click" Margin="8,0,0,0" Padding="10,4" MinHeight="0"/>
                    </StackPanel>
                </Grid>
                <Border Background="{StaticResource CrustBrush}" CornerRadius="6" Padding="6" Margin="0,6,0,0">
                    <ListBox x:Name="CatalogList" Background="Transparent" BorderThickness="0" SelectionChanged="CatalogList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource LavenderBrush}" Text="{Binding Name}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Text="{Binding Description}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Installed"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Refresh" Style="{StaticResource FlatButton}" Click="RefreshInstalled_Click" Padding="10,4" MinHeight="0"/>
                        <Button Content="Toggle enabled" Style="{StaticResource FlatButton}" Click="Toggle_Click" Margin="8,0,0,0" Padding="10,4" MinHeight="0"/>
                        <Button Content="Remove (on reboot)" Style="{StaticResource DangerButton}" Click="Remove_Click" Margin="8,0,0,0" Padding="10,4" MinHeight="0"/>
                    </StackPanel>
                </Grid>
                <Border Background="{StaticResource CrustBrush}" CornerRadius="6" Padding="6" Margin="0,6,0,0">
                    <ListBox x:Name="InstalledList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="4,2">
                                    <Run Text="{Binding Name}"/>
                                    <Run Text="("/>
                                    <Run Text="{Binding Id}"/>
                                    <Run Text=") "/>
                                    <Run Text="{Binding Version}"/>
                                    <Run Text=" • "/>
                                    <Run Text="{Binding Enabled}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText" Foreground="{StaticResource YellowBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Style="{StaticResource FlatButton}" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
