<UserControl x:Class="AndroidEmulatorPlus.Views.InstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Install / SDK"/>
            <TextBlock Style="{StaticResource SubheaderText}" Text="Detect Android SDK + emulator, or install the command-line tools if you're starting fresh."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Current state"/>
                    <Grid Margin="0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SDK Root" Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource SubtextBrush}"/>
                        <TextBlock Text="{Binding SdkPathText}" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="platform-tools" Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasPlatformTools, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="emulator" Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasEmulator, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="cmdline-tools" Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasCmdlineTools, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="3" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="Status" Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding StatusText}" Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Foreground="{DynamicResource LavenderBrush}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Open SDK Folder" Style="{StaticResource FlatButton}" Command="{Binding OpenSdkFolderCommand}" Margin="8,0,0,0"/>
                        <Button Content="Accept all SDK licenses" Style="{StaticResource FlatButton}" Command="{Binding AcceptLicensesCommand}" Margin="8,0,0,0"
                                IsEnabled="{Binding HasCmdlineTools}"
                                ToolTip="Pipes y\n into sdkmanager --licenses so future installs run unattended"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SDK package updates"/>
                    <TextBlock Text="{Binding SdkPackageUpdateText}" Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,10,-8,0">
                        <Button Content="Check updates" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                Command="{Binding RefreshSdkPackagesCommand}"
                                IsEnabled="{Binding HasCmdlineTools}"/>
                        <Button Content="Update listed packages" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                Command="{Binding UpdateSdkPackagesCommand}"
                                IsEnabled="{Binding HasSdkPackageUpdates}"/>
                    </WrapPanel>
                    <ItemsControl ItemsSource="{Binding SdkPackageUpdates}"
                                  Visibility="{Binding HasSdkPackageUpdates, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource SurfaceBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Path}" FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="{DynamicResource LavenderBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource SubtextBrush}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource YellowBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} → {1}">
                                                    <Binding Path="InstalledVersion"/>
                                                    <Binding Path="AvailableVersion"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hardware acceleration"/>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                        Runs <Run FontFamily="Cascadia Mono, Consolas">emulator -accel-check</Run> to verify that Windows Hypervisor Platform / Hyper-V is enabled so the emulator can use hardware virtualization.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Run accel-check" Style="{StaticResource FlatButton}" Command="{Binding CheckAccelCommand}"/>
                        <TextBlock Text="{Binding AccelText}" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource LavenderBrush}"/>
                    </StackPanel>
                    <Border Background="{DynamicResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,10,0,0"
                            Visibility="{Binding AccelOk, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource YellowBrush}" FontWeight="SemiBold" Margin="0,0,0,4" Text="Remediation"/>
                            <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap" FontSize="12">
                                Hardware virtualization is gated by a Windows feature and (on Intel) a BIOS flag. Open one of:
                            </TextBlock>
                            <WrapPanel Margin="0,8,-8,-8">
                                <Button Content="Windows Hypervisor Platform docs" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="https://learn.microsoft.com/en-us/virtualization/api/hypervisor-platform/hypervisor-platform"/>
                                <Button Content="Open 'Turn Windows features on/off'" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenFeaturesCommand}"/>
                                <Button Content="Android Studio emulator-accel docs" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="https://developer.android.com/studio/run/emulator-acceleration"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Visibility="{Binding HasDiagnostics, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Diagnostics"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Open logs folder" Style="{StaticResource FlatButton}" Command="{Binding OpenLogsFolderCommand}"/>
                            <Button Content="Clear crash.log" Style="{StaticResource DangerButton}" Command="{Binding ClearCrashLogCommand}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{DynamicResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                        <TextBlock Text="{Binding DiagnosticsText}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}" TextWrapping="NoWrap" MaxHeight="220"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="If nothing is installed"/>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                        Option 1 — install just the command-line tools (~150 MB). Then use the AVDs tab to pull a system image and create an emulator.
                    </TextBlock>
                    <WrapPanel Margin="0,10,-8,-8">
                        <Button Content="Download command-line tools" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding DownloadCmdlineToolsCommand}" IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                        <Button Content="Cancel" Style="{StaticResource DangerButton}" Margin="0,0,8,8"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                        <TextBlock Text="{Binding Step}" Foreground="{DynamicResource OverlayBrush}" Margin="4,0,8,8" VerticalAlignment="Center"/>
                    </WrapPanel>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"
                                 IsIndeterminate="{Binding IsDownloadProgressIndeterminate}"
                                 Margin="0,6,0,0"
                                 Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock Text="{Binding DownloadProgressText}" Foreground="{DynamicResource SubtextBrush}"
                               Margin="0,6,0,0" FontSize="12"
                               Visibility="{Binding HasDownloadProgress, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock Text="{Binding CmdlineToolsNote}" Foreground="{DynamicResource YellowBrush}" Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12"
                               Visibility="{Binding HasCmdlineToolsNote, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" Margin="0,18,0,0" TextWrapping="Wrap">
                        Option 2 — install Android Studio (~1.2 GB). Includes the Device Manager UI plus all SDK components.
                    </TextBlock>
                    <Button Content="Open developer.android.com/studio" Style="{StaticResource FlatButton}" Command="{Binding OpenStudioDownloadPageCommand}" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
