<UserControl x:Class="AndroidEmulatorPlus.Views.InstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Install / SDK"/>
            <TextBlock Style="{StaticResource SubheaderText}" Text="Detect Android SDK + emulator, or install the command-line tools if you're starting fresh."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Current state"/>
                    <Grid Margin="0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SDK Root" Grid.Row="0" Grid.Column="0" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock Text="{Binding SdkPathText}" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="platform-tools" Grid.Row="1" Grid.Column="0" Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasPlatformTools, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="emulator" Grid.Row="2" Grid.Column="0" Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasEmulator, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="cmdline-tools" Grid.Row="3" Grid.Column="0" Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding HasCmdlineTools, Converter={x:Static views:BoolStatusConverter.Instance}}" Grid.Row="3" Grid.Column="1" Margin="0,6,0,0"/>
                        <TextBlock Text="Status" Grid.Row="4" Grid.Column="0" Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding StatusText}" Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Foreground="{StaticResource LavenderBrush}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Open SDK Folder" Style="{StaticResource FlatButton}" Command="{Binding OpenSdkFolderCommand}" Margin="8,0,0,0"/>
                        <Button Content="Accept all SDK licenses" Style="{StaticResource FlatButton}" Command="{Binding AcceptLicensesCommand}" Margin="8,0,0,0"
                                IsEnabled="{Binding HasCmdlineTools}"
                                ToolTip="Pipes y\n into sdkmanager --licenses so future installs run unattended"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hardware acceleration"/>
                    <TextBlock Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap">
                        Runs <Run FontFamily="Cascadia Mono, Consolas">emulator -accel-check</Run> to verify that Windows Hypervisor Platform / Hyper-V is enabled so the emulator can use hardware virtualization.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Run accel-check" Style="{StaticResource FlatButton}" Command="{Binding CheckAccelCommand}"/>
                        <TextBlock Text="{Binding AccelText}" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LavenderBrush}"/>
                    </StackPanel>
                    <Border Background="{StaticResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,10,0,0"
                            Visibility="{Binding AccelOk, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource YellowBrush}" FontWeight="SemiBold" Margin="0,0,0,4" Text="Remediation"/>
                            <TextBlock Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" FontSize="12">
                                Hardware virtualization is gated by a Windows feature and (on Intel) a BIOS flag. Open one of:
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Windows Hypervisor Platform docs" Style="{StaticResource FlatButton}"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="https://learn.microsoft.com/en-us/virtualization/api/hypervisor-platform/hypervisor-platform"/>
                                <Button Content="Open 'Turn Windows features on/off'" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                                        Command="{Binding OpenFeaturesCommand}"/>
                                <Button Content="Android Studio emulator-accel docs" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="https://developer.android.com/studio/run/emulator-acceleration"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Visibility="{Binding HasDiagnostics, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Diagnostics"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Open logs folder" Style="{StaticResource FlatButton}" Command="{Binding OpenLogsFolderCommand}"/>
                            <Button Content="Clear crash.log" Style="{StaticResource DangerButton}" Command="{Binding ClearCrashLogCommand}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{StaticResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                        <TextBlock Text="{Binding DiagnosticsText}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                   Foreground="{StaticResource SubtextBrush}" TextWrapping="NoWrap" MaxHeight="220"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Appearance"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Theme" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"/>
                    </Grid>
                    <TextBlock Text="{Binding ThemeNote}" Foreground="{StaticResource YellowBrush}" Margin="0,6,0,0" FontSize="12"/>
                    <TextBlock Foreground="{StaticResource OverlayBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">mocha</Run>: Catppuccin Mocha (dark) — default. <Run FontWeight="SemiBold">latte</Run>: Catppuccin Latte (light) — for corporate screen-shares or bright rooms.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="If nothing is installed"/>
                    <TextBlock Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap">
                        Option 1 — install just the command-line tools (~150 MB). Then use the AVDs tab to pull a system image and create an emulator.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Download command-line tools" Style="{StaticResource PrimaryButton}" Command="{Binding DownloadCmdlineToolsCommand}" IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                        <TextBlock Text="{Binding Step}" Foreground="{StaticResource OverlayBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CmdlineToolsNote}" Foreground="{StaticResource YellowBrush}" Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12"
                               Visibility="{Binding HasCmdlineToolsNote, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                    <TextBlock Foreground="{StaticResource SubtextBrush}" Margin="0,18,0,0" TextWrapping="Wrap">
                        Option 2 — install Android Studio (~1.2 GB). Includes the Device Manager UI plus all SDK components.
                    </TextBlock>
                    <Button Content="Open developer.android.com/studio" Style="{StaticResource FlatButton}" Command="{Binding OpenStudioDownloadPageCommand}" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
