<UserControl x:Class="AndroidEmulatorPlus.Views.MigrateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Migrate from Phone"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Copy APKs and app data from a USB-attached phone to the running emulator.
                Internal data copy requires root on BOTH ends.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Source (phone)" Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding PhoneStatus}" Margin="0,4,0,0" Foreground="{StaticResource LavenderBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Target (emulator)" Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding EmuStatus}" Margin="0,4,0,0" Foreground="{StaticResource LavenderBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Scope"/>
                <WrapPanel>
                    <CheckBox Content="APKs" IsChecked="{Binding DoApk}" Margin="0,0,18,0"/>
                    <CheckBox Content="Internal data (/data/data)" IsChecked="{Binding DoInternal}" Margin="0,0,18,0"/>
                    <CheckBox Content="External data (/sdcard/Android/data)" IsChecked="{Binding DoExternal}"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Width="240" Margin="8,0,0,0"/>
                    <Button Content="All" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="12,0,0,0"/>
                    <Button Content="None" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="8,0,0,0"/>
                    <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                <ItemsControl ItemsSource="{Binding FilteredPackages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Start Migration" Style="{StaticResource PrimaryButton}" Command="{Binding MigrateCommand}"/>
                <ProgressBar Grid.Column="1" Margin="14,0" VerticalAlignment="Center"
                             Value="{Binding ProgressFraction}" Minimum="0" Maximum="1"/>
                <TextBlock Grid.Column="2" Text="{Binding StepText}" Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource GreenBrush}" Margin="0,6,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
