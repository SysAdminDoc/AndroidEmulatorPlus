<UserControl x:Class="AndroidEmulatorPlus.Views.MigrateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Migrate from Phone"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Copy APKs and app data from a USB-attached phone to the running emulator.
                Internal data copy requires root on BOTH ends.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Source (phone)" Foreground="{DynamicResource OverlayBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding PhoneStatus}" Margin="0,4,0,0" Foreground="{DynamicResource LavenderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Target (emulator)" Foreground="{DynamicResource OverlayBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding EmuStatus}" Margin="0,4,0,0" Foreground="{DynamicResource LavenderBrush}"/>
                    </StackPanel>
                </Grid>
                <Expander Header="Pair a phone over Wi-Fi (Android 11+)" Foreground="{DynamicResource SubtextBrush}" Margin="0,12,0,0" IsExpanded="False">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8">
                            On the phone: Developer options → Wireless debugging → Pair using pairing code. Copy the displayed <Run FontFamily="Cascadia Mono">host:port</Run> + 6-digit code below. After pairing, copy the OTHER <Run FontFamily="Cascadia Mono">host:port</Run> from the same screen into Connect.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Pair host:port" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding PairHost, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0">
                                <TextBlock Text="6-digit code" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding PairCode, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Pair" Style="{StaticResource FlatButton}" Margin="6,18,0,0" VerticalAlignment="Bottom"
                                    Command="{Binding PairCommand}"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Connect host:port" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding ConnectHost, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Connect" Style="{StaticResource PrimaryButton}" Margin="6,18,0,0" VerticalAlignment="Bottom"
                                    Command="{Binding ConnectCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding PairStatus}" Foreground="{DynamicResource YellowBrush}" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Scope"/>
                <WrapPanel Margin="0,0,-18,-6">
                    <CheckBox Content="APKs" IsChecked="{Binding DoApk}" Margin="0,0,18,6"/>
                    <CheckBox Content="Internal data (/data/data)" IsChecked="{Binding DoInternal}" Margin="0,0,18,6"/>
                    <CheckBox Content="External data (/sdcard/Android/data)" IsChecked="{Binding DoExternal}" Margin="0,0,18,6"/>
                    <CheckBox Content="OBB game data" IsChecked="{Binding DoObb}" Margin="0,0,18,6" ToolTip="Copies /sdcard/Android/obb/&lt;pkg&gt;. Opt in because game OBBs are often multi-GB."/>
                </WrapPanel>
                <CheckBox Content="Force-stop source phone before tar" IsChecked="{Binding ForceStopOnPhone}" Margin="0,8,0,0"
                          ToolTip="Closes the app on the phone before tarring /data/data so SQLite databases are not captured mid-write. The target emulator app is also stopped before restore."/>
                <CheckBox Content="Force-migrate no-backup apps (override allowBackup=false skip)" IsChecked="{Binding ForceDataForNoBackup}" Margin="0,4,0,0"
                          ToolTip="By default the data leg is skipped for packages with android:allowBackup=&quot;false&quot; because the restored data is usually rejected. Enable to push it anyway."/>
                <WrapPanel Margin="0,14,-8,-8">
                    <StackPanel Width="260" Margin="0,0,12,8">
                        <TextBlock Text="Filter packages" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Filter phone packages"/>
                    </StackPanel>
                    <Button Content="Select all" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="0,20,8,8"/>
                    <Button Content="Select none" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="0,20,8,8"/>
                    <Button Content="Refresh packages" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" Margin="0,20,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460"
                            Visibility="{Binding HasPackages, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="No phone packages loaded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource MicrocopyText}" TextAlignment="Center" Margin="0,6,0,0"
                               Text="Connect a USB-debugging phone or pair over Wi-Fi, then refresh to choose packages for migration."/>
                    <Button Content="Refresh packages" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460"
                            Visibility="{Binding IsPackageFilterEmpty, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="No packages match this filter" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource MicrocopyText}" TextAlignment="Center" Margin="0,6,0,0"
                               Text="Clear or broaden the filter to return to the loaded phone package list."/>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320"
                              Visibility="{Binding HasFilteredPackages, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                    <ItemsControl ItemsSource="{Binding FilteredPackages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="9,7" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"/>
                                <Border Grid.Column="1" Style="{StaticResource StatusPill}" Margin="8,0,0,0"
                                        Background="{DynamicResource YellowBrush}"
                                        Visibility="{Binding AllowBackup, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}"
                                        ToolTip="android:allowBackup=&quot;false&quot;; restored data is usually rejected by the app">
                                    <TextBlock Text="No backup" FontSize="11" Foreground="{DynamicResource CrustBrush}" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Start Migration" Style="{StaticResource PrimaryButton}" Command="{Binding MigrateCommand}"
                            IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                    <Button Content="Cancel" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                    <Button Content="Retry failed" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                            Command="{Binding RetryFailedCommand}"
                            Visibility="{Binding HasFailedReceipt, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
                <ProgressBar Grid.Column="1" Margin="14,0" VerticalAlignment="Center"
                             Value="{Binding ProgressFraction}" Minimum="0" Maximum="1"/>
                <TextBlock Grid.Column="2" Text="{Binding StepText}" Foreground="{DynamicResource OverlayBrush}" VerticalAlignment="Center"
                           MaxWidth="280" TextTrimming="CharacterEllipsis"/>
            </Grid>
            <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource GreenBrush}" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding FailedReceiptText}" Foreground="{DynamicResource YellowBrush}" Margin="0,4,0,0"
                       Visibility="{Binding HasFailedReceipt, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="On-disk cache"/>
                        <Button Grid.Column="1" Content="Recalculate" Style="{StaticResource FlatButton}" Command="{Binding RefreshCacheCommand}" Padding="10,4" MinHeight="0"/>
                    </Grid>
                    <TextBlock Text="{Binding CacheSummary}" Foreground="{DynamicResource SubtextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Clear migration cache" Style="{StaticResource FlatButton}" Command="{Binding ClearTransferCacheCommand}"/>
                        <Button Content="Clear root cache" Style="{StaticResource FlatButton}" Command="{Binding ClearRootCacheCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap">
                        Migration cache holds the temporary tarballs and split-APK extracts in <Run FontFamily="Cascadia Mono">%LOCALAPPDATA%\AndroidEmulatorPlus\transfer\</Run>.
                        Root cache holds the rootAVD clone + downloaded Magisk APK; clearing forces a re-clone next time you Root.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
