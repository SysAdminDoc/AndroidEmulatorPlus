<UserControl x:Class="AndroidEmulatorPlus.Views.MigrateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Migrate from Phone"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Copy APKs and app data from a USB-attached phone to the running emulator.
                Internal data copy requires root on BOTH ends.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Source (phone)" Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding PhoneStatus}" Margin="0,4,0,0" Foreground="{StaticResource LavenderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Target (emulator)" Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding EmuStatus}" Margin="0,4,0,0" Foreground="{StaticResource LavenderBrush}"/>
                    </StackPanel>
                </Grid>
                <Expander Header="Pair a phone over Wi-Fi (Android 11+)" Foreground="{StaticResource SubtextBrush}" Margin="0,12,0,0" IsExpanded="False">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Foreground="{StaticResource OverlayBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8">
                            On the phone: Developer options → Wireless debugging → Pair using pairing code. Copy the displayed <Run FontFamily="Cascadia Mono">host:port</Run> + 6-digit code below. After pairing, copy the OTHER <Run FontFamily="Cascadia Mono">host:port</Run> from the same screen into Connect.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Pair host:port" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding PairHost, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0">
                                <TextBlock Text="6-digit code" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding PairCode, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Pair" Style="{StaticResource FlatButton}" Margin="6,18,0,0" VerticalAlignment="Bottom"
                                    Command="{Binding PairCommand}"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Connect host:port" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4" FontSize="11"/>
                                <TextBox Text="{Binding ConnectHost, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Connect" Style="{StaticResource PrimaryButton}" Margin="6,18,0,0" VerticalAlignment="Bottom"
                                    Command="{Binding ConnectCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding PairStatus}" Foreground="{StaticResource YellowBrush}" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Scope"/>
                <WrapPanel>
                    <CheckBox Content="APKs" IsChecked="{Binding DoApk}" Margin="0,0,18,0"/>
                    <CheckBox Content="Internal data (/data/data)" IsChecked="{Binding DoInternal}" Margin="0,0,18,0"/>
                    <CheckBox Content="External data (/sdcard/Android/data)" IsChecked="{Binding DoExternal}"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Width="240" Margin="8,0,0,0"/>
                    <Button Content="All" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="12,0,0,0"/>
                    <Button Content="None" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="8,0,0,0"/>
                    <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                <ItemsControl ItemsSource="{Binding FilteredPackages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Start Migration" Style="{StaticResource PrimaryButton}" Command="{Binding MigrateCommand}"
                            IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                    <Button Content="✗ Cancel" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
                <ProgressBar Grid.Column="1" Margin="14,0" VerticalAlignment="Center"
                             Value="{Binding ProgressFraction}" Minimum="0" Maximum="1"/>
                <TextBlock Grid.Column="2" Text="{Binding StepText}" Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource GreenBrush}" Margin="0,6,0,0"/>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="On-disk cache"/>
                        <Button Grid.Column="1" Content="Recalculate" Style="{StaticResource FlatButton}" Command="{Binding RefreshCacheCommand}" Padding="10,4" MinHeight="0"/>
                    </Grid>
                    <TextBlock Text="{Binding CacheSummary}" Foreground="{StaticResource SubtextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Clear migration cache" Style="{StaticResource FlatButton}" Command="{Binding ClearTransferCacheCommand}"/>
                        <Button Content="Clear root cache" Style="{StaticResource FlatButton}" Command="{Binding ClearRootCacheCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource OverlayBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap">
                        Migration cache holds the temporary tarballs and split-APK extracts in <Run FontFamily="Cascadia Mono">%LOCALAPPDATA%\AndroidEmulatorPlus\transfer\</Run>.
                        Root cache holds the rootAVD clone + downloaded Magisk APK; clearing forces a re-clone next time you Root.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
