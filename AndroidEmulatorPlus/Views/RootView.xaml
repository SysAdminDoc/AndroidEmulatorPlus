<UserControl x:Class="AndroidEmulatorPlus.Views.RootView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Root via Magisk"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Patches the system image's ramdisk with Magisk (via rootAVD). Keeps Google Play working.
                The emulator must be running when you press Root so rootAVD can shell into it.
            </TextBlock>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Target AVD"/>
                    <ComboBox ItemsSource="{Binding Avds}" SelectedItem="{Binding SelectedAvd}" DisplayMemberPath="Name"
                             AutomationProperties.Name="Target AVD for rooting"/>
                    <ProgressBar IsIndeterminate="{Binding IsBusy}" Margin="0,12,0,0"
                                 Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                                 AutomationProperties.Name="Root operation progress"/>
                    <TextBlock Text="{Binding Status}" Margin="0,12,0,0" Foreground="{DynamicResource LavenderBrush}"/>
                    <TextBlock Text="{Binding Step}" Margin="0,4,0,0" Foreground="{DynamicResource OverlayBrush}"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"
                                 IsIndeterminate="{Binding IsDownloadProgressIndeterminate}"
                                 Margin="0,10,0,0"
                                 Visibility="{Binding HasDownloadProgress, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                                 AutomationProperties.Name="Download progress"/>
                    <TextBlock Text="{Binding DownloadProgressText}" Margin="0,4,0,0" FontSize="12"
                               Foreground="{DynamicResource SubtextBrush}"
                               Visibility="{Binding HasDownloadProgress, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}"
                    Background="{DynamicResource SurfaceBrush}"
                    Visibility="{Binding NeedsLaunch, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource YellowBrush}" FontWeight="SemiBold" TextWrapping="Wrap"
                               Text="rootAVD needs a running emulator to patch the ramdisk through adb."/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Launch &amp; root" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LaunchAndRootCommand}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Launch and root AVD"/>
                        <TextBlock Text="Launches the selected AVD, waits for boot, then runs the root flow."
                                   Foreground="{DynamicResource SubtextBrush}" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Actions"/>
                    <WrapPanel Margin="0,0,-8,-8">
                        <Button Content="Root with latest Magisk" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding RootCommand}" IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}" AutomationProperties.Name="Root with latest Magisk"/>
                        <Button Content="Cancel" Style="{StaticResource DangerButton}" Margin="0,0,8,8"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                                AutomationProperties.Name="Cancel root operation"/>
                        <Button Content="Verify and persist policy" Style="{StaticResource FlatButton}" Command="{Binding VerifyCommand}" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}" AutomationProperties.Name="Verify root and persist Magisk policy"/>
                        <Button Content="Un-root and restore ramdisk" Style="{StaticResource DangerButton}" Command="{Binding UnRootCommand}" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}" AutomationProperties.Name="Un-root and restore stock ramdisk"/>
                        <Button Content="Dry run (LISTONLY)" Style="{StaticResource FlatButton}" Command="{Binding DryRunCommand}" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                ToolTip="Runs rootAVD LISTONLY to preview which AVDs would be patched. No files are changed." AutomationProperties.Name="Root dry run"/>
                        <Button Content="Modules..." Style="{StaticResource FlatButton}" Command="{Binding OpenModulesCommand}" Margin="0,0,8,8"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                ToolTip="Magisk module manager - install Shamiko, LSPosed, PlayIntegrityFork, etc. on the rooted emulator." AutomationProperties.Name="Open Magisk modules"/>
                    </WrapPanel>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" Margin="0,14,0,0" TextWrapping="Wrap">
                        Workflow: 1. Launch the AVD from the AVDs tab. 2. Press "Root with latest Magisk".
                        3. Cold boot the AVD from the AVDs tab. 4. Press "Verify and persist policy".
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12">
                        Backups (.original) of the stock ramdisk are kept inside the system-image folder. Un-Root copies them back.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Security testing"/>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                        Install a proxy CA into Android's system trust store and deploy frida-server on the attached rooted emulator.
                    </TextBlock>
                    <WrapPanel Margin="0,12,-8,-8">
                        <Button Content="Install CA cert..." Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                Command="{Binding InstallCaCertCommand}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Install CA certificate"/>
                        <Button Content="Deploy Frida server" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                Command="{Binding DeployFridaCommand}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Deploy Frida server"/>
                        <Button Content="Stop Frida" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                Command="{Binding StopFridaCommand}"
                                IsEnabled="{Binding IsFridaRunning}"
                                AutomationProperties.Name="Stop Frida server"/>
                        <Button Content="Refresh Frida" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                Command="{Binding RefreshFridaStatusCommand}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                                AutomationProperties.Name="Refresh Frida status"/>
                    </WrapPanel>
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CA cert" Foreground="{DynamicResource OverlayBrush}" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding CaCertStatus}" Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="Frida" Foreground="{DynamicResource OverlayBrush}" Margin="0,6,0,0" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding FridaStatus}" Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" Grid.Row="1" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="KernelSU manual path"/>
                    <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                        KernelSU uses a custom kernel image instead of the rootAVD ramdisk flow. Advanced users can test it manually:
                        <LineBreak/>1. Build or download a KernelSU-patched kernel for the matching API level.
                        <LineBreak/>2. Replace <Run FontFamily="Cascadia Mono">&lt;sys-image&gt;/kernel-ranchu</Run> with the patched kernel.
                        <LineBreak/>3. Cold-boot the AVD and install the KernelSU manager APK from <Run FontFamily="Cascadia Mono">github.com/tiann/KernelSU/releases</Run>.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
