<UserControl x:Class="AndroidEmulatorPlus.Views.RootView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Root via Magisk"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Patches the system image's ramdisk with Magisk (via rootAVD). Keeps Google Play working.
                The emulator must be running when you press Root so rootAVD can shell into it.
            </TextBlock>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Target AVD"/>
                    <ComboBox ItemsSource="{Binding Avds}" SelectedItem="{Binding SelectedAvd}" DisplayMemberPath="Name"/>
                    <TextBlock Text="{Binding Status}" Margin="0,12,0,0" Foreground="{StaticResource LavenderBrush}"/>
                    <TextBlock Text="{Binding Step}" Margin="0,4,0,0" Foreground="{StaticResource OverlayBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" xmlns:views="clr-namespace:AndroidEmulatorPlus.Views"
                    Background="{StaticResource SurfaceBrush}"
                    Visibility="{Binding NeedsLaunch, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource YellowBrush}" FontWeight="SemiBold" TextWrapping="Wrap">
                        ⚠ rootAVD needs a running emulator to patch the ramdisk through adb.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Launch &amp; root" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LaunchAndRootCommand}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                        <TextBlock Text="Launches the selected AVD, waits for boot, then runs the root flow."
                                   Foreground="{StaticResource SubtextBrush}" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Actions"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Root with Latest Magisk" Style="{StaticResource PrimaryButton}" Command="{Binding RootCommand}" IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}" xmlns:views="clr-namespace:AndroidEmulatorPlus.Views"/>
                        <Button Content="✗ Cancel" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsBusy, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                        <Button Content="Verify + Persist Policy" Style="{StaticResource FlatButton}" Command="{Binding VerifyCommand}" Margin="8,0,0,0"/>
                        <Button Content="Un-Root (Restore Ramdisk)" Style="{StaticResource DangerButton}" Command="{Binding UnRootCommand}" Margin="8,0,0,0"/>
                        <Button Content="Dry run (LISTONLY)" Style="{StaticResource FlatButton}" Command="{Binding DryRunCommand}" Margin="8,0,0,0"
                                ToolTip="Runs rootAVD LISTONLY to preview which AVDs would be patched. No files are changed."/>
                        <Button Content="Modules…" Style="{StaticResource FlatButton}" Command="{Binding OpenModulesCommand}" Margin="8,0,0,0"
                                ToolTip="Magisk module manager — install Shamiko, LSPosed, PlayIntegrityFork, etc. on the rooted emulator (R-03)."/>
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource SubtextBrush}" Margin="0,14,0,0" TextWrapping="Wrap">
                        Workflow:  ① Launch the AVD from the AVDs tab.  ② Press "Root with Latest Magisk".
                        ③ Cold-boot the AVD (AVDs tab → Cold Boot).  ④ Press "Verify + Persist Policy".
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource OverlayBrush}" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12">
                        Backups (.original) of the stock ramdisk are kept inside the system-image folder. Un-Root copies them back.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="KernelSU (alternative root)"/>
                    <TextBlock Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap">
                        KernelSU requires a custom kernel image patched into the AVD's system-image, which is out of scope for this tool's rootAVD-based flow. To experiment manually:
                        <LineBreak/>1. Build or download a KernelSU-patched kernel for the matching API level.
                        <LineBreak/>2. Replace <Run FontFamily="Cascadia Mono">&lt;sys-image&gt;/kernel-ranchu</Run> with the patched kernel.
                        <LineBreak/>3. Cold-boot the AVD and install the KernelSU manager APK from <Run FontFamily="Cascadia Mono">github.com/tiann/KernelSU/releases</Run>.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
