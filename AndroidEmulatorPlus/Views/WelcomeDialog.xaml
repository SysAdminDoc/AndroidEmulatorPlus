<Window x:Class="AndroidEmulatorPlus.Views.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome"
        Width="640" Height="540"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource LavenderBrush}" Text="Set up AndroidEmulatorPlus"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap" Margin="0,4,0,12">
            This setup guide follows the four-step flow the app is built around. Each step opens the matching tab; close it any time to explore on your own.
        </TextBlock>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border x:Name="SdkCard" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="1. Install / SDK"/>
                        <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                            If you do not have the Android SDK yet, the Install tab can fetch the command-line tools. Then "Browse online..." on the AVDs tab installs a system image.
                        </TextBlock>
                        <TextBlock x:Name="SdkStatus" Foreground="{DynamicResource YellowBrush}" Margin="0,6,0,0" FontWeight="SemiBold"/>
                        <Button Content="Go to Install / SDK" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="GoToInstall_Click" AutomationProperties.Name="Go to Install SDK tab"/>
                    </StackPanel>
                </Border>
                <Border x:Name="AvdCard" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="2. Create an AVD"/>
                        <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                            From the AVDs tab pick a device profile plus a system image. The "Browse online..." button installs new images through sdkmanager.
                        </TextBlock>
                        <TextBlock x:Name="AvdStatus" Foreground="{DynamicResource YellowBrush}" Margin="0,6,0,0" FontWeight="SemiBold"/>
                        <Button Content="Go to AVDs" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="GoToAvd_Click" AutomationProperties.Name="Go to AVDs tab"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="3. Root (optional)"/>
                        <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                            Launch the AVD, then click "Root with Latest Magisk" on the Root tab. The Verify + Persist Policy button persists Magisk's shell→allow policy so future `adb shell su` calls don't trigger the dialog. Skip this step if you just want a vanilla emulator.
                        </TextBlock>
                        <Button Content="Go to Root" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="GoToRoot_Click" AutomationProperties.Name="Go to Root tab"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="4. Migrate from phone (optional)"/>
                        <TextBlock Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap">
                            Connect a USB-debugging-enabled phone (or pair over Wi-Fi from the Migrate tab) and pick the packages to copy. Internal data copy requires root on BOTH ends.
                        </TextBlock>
                        <Button Content="Go to Migrate" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="GoToMigrate_Click" AutomationProperties.Name="Go to Migrate tab"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="ShowAllBox" Content="Show completed steps" IsChecked="False" VerticalAlignment="Center" Checked="ShowAll_Toggled" Unchecked="ShowAll_Toggled" AutomationProperties.Name="Show completed steps"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <CheckBox x:Name="DontShowBox" Content="Don't show again" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" AutomationProperties.Name="Do not show welcome again"/>
                <Button Content="Close" Style="{StaticResource PrimaryButton}" Click="Close_Click" IsDefault="True" IsCancel="True" AutomationProperties.Name="Close welcome dialog"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
