<UserControl x:Class="AndroidEmulatorPlus.Views.LogcatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Logcat"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Stream <Run FontFamily="Cascadia Mono">adb logcat -v threadtime</Run> from the attached emulator. The filter field accepts logcat priority specs like <Run FontFamily="Cascadia Mono">*:E</Run> (errors only) or <Run FontFamily="Cascadia Mono">com.example:V *:S</Run> (verbose for one tag, silent everything else).
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Priority filter" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Package prefix (optional)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PackageFilter, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="▶ Start" Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsStreaming, Converter={x:Static views:NotBoolConverter.Instance}}"/>
                    <Button Content="■ Stop" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding IsStreaming}"/>
                    <Button Content="Clear buffer (adb logcat -c)" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                            Command="{Binding ClearBufferCommand}"/>
                    <Button Content="Clear view" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                            Command="{Binding ClearViewCommand}"/>
                    <Button Content="Save…" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                            Command="{Binding SaveCommand}"/>
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource OverlayBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" CornerRadius="6" Padding="8" Margin="0,12,0,0">
            <ListBox ItemsSource="{Binding Lines}" x:Name="LinesList"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
