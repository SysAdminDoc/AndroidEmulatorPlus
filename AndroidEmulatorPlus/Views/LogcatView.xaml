<UserControl x:Class="AndroidEmulatorPlus.Views.LogcatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Logcat"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Stream <Run FontFamily="Cascadia Mono">adb logcat -v threadtime</Run> from the attached emulator. The filter field accepts logcat priority specs like <Run FontFamily="Cascadia Mono">*:E</Run> (errors only) or <Run FontFamily="Cascadia Mono">com.example:V *:S</Run> (verbose for one tag, silent everything else).
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Priority filter" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"
                                 AutomationProperties.Name="Logcat priority filter"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Package prefix (optional)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding PackageFilter, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"
                                 AutomationProperties.Name="Logcat package prefix"/>
                    </StackPanel>
                </Grid>
                <WrapPanel Margin="0,12,-8,-8">
                    <Button Content="Start stream" Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,8"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsStreaming, Converter={x:Static views:NotBoolConverter.Instance}}"
                            AutomationProperties.Name="Start logcat stream"/>
                    <Button Content="Stop" Style="{StaticResource DangerButton}" Margin="0,0,8,8"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding IsStreaming}"
                            AutomationProperties.Name="Stop logcat stream"/>
                    <Button Content="Clear device buffer" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                            Command="{Binding ClearBufferCommand}"
                            AutomationProperties.Name="Clear device logcat buffer"/>
                    <Button Content="Clear view" Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                            Command="{Binding ClearViewCommand}"
                            AutomationProperties.Name="Clear log view"/>
                    <Button Content="Save log..." Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                            Command="{Binding SaveCommand}"
                            AutomationProperties.Name="Save log to file"/>
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource OverlayBrush}" Margin="6,0,8,8" VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,12,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440"
                            Visibility="{Binding Lines.Count, Converter={x:Static views:ZeroCountToVisibilityConverter.Instance}}">
                    <TextBlock Text="No log lines yet" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource MicrocopyText}" TextAlignment="Center" Margin="0,6,0,0"
                               Text="Start streaming to watch emulator logs. Use the priority filter to keep the signal focused."/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Lines}" x:Name="LinesList"
                     Background="Transparent" BorderThickness="0"
                     AutomationProperties.Name="Logcat output lines"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Visibility="{Binding Lines.Count, Converter={x:Static views:CountToVisibilityConverter.Instance}}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
