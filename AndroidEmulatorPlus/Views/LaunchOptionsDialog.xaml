<Window x:Class="AndroidEmulatorPlus.Views.LaunchOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launch options"
        Width="540" SizeToContent="Height"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="24,20">
        <TextBlock x:Name="HeaderText"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource LavenderBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>
        <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12">
            All fields are optional. Empty fields are omitted from the emulator command line.
        </TextBlock>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <CheckBox x:Name="ColdBootBox" Content="Cold boot" Grid.ColumnSpan="2" Margin="0,2" AutomationProperties.Name="Cold boot"/>
            <CheckBox x:Name="WipeBox" Grid.Row="1" Content="Wipe data on next launch" Grid.ColumnSpan="2" Margin="0,2" AutomationProperties.Name="Wipe data on next launch"/>
            <CheckBox x:Name="NoWindowBox" Grid.Row="2" Content="Headless (-no-window)" Grid.ColumnSpan="2" Margin="0,2" AutomationProperties.Name="Headless mode"/>
            <CheckBox x:Name="NoAudioBox" Grid.Row="3" Content="No audio (-no-audio)" Grid.ColumnSpan="2" Margin="0,2" AutomationProperties.Name="No audio"/>
            <CheckBox x:Name="MultiDisplayBox" Grid.Row="4" Content="Multi-display (-multi-display)" Grid.ColumnSpan="2" Margin="0,2"
                      ToolTip="Enables foldable/multi-screen testing" AutomationProperties.Name="Multi-display mode"/>
            <CheckBox x:Name="PeerNetworkBox" Grid.Row="5" Content="Peer networking (-network-backend slirp-peer)" Grid.ColumnSpan="2" Margin="0,2"
                      ToolTip="Enables peer-to-peer networking between multiple AVDs" AutomationProperties.Name="Peer networking mode"/>

            <TextBlock Grid.Row="6" Text="HTTP proxy" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <TextBox  Grid.Row="6" Grid.Column="1" x:Name="HttpProxyBox" Margin="0,8,0,0" AutomationProperties.Name="Launch HTTP proxy"/>

            <TextBlock Grid.Row="7" Text="DNS server" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <TextBox  Grid.Row="7" Grid.Column="1" x:Name="DnsBox" Margin="0,8,0,0" AutomationProperties.Name="Launch DNS server"/>

            <TextBlock Grid.Row="8" Text="Front camera" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <ComboBox Grid.Row="8" Grid.Column="1" x:Name="FrontCameraBox" Margin="0,8,0,0" IsEditable="True" AutomationProperties.Name="Front camera">
                <ComboBoxItem>none</ComboBoxItem>
                <ComboBoxItem>emulated</ComboBoxItem>
                <ComboBoxItem>webcam0</ComboBoxItem>
            </ComboBox>

            <TextBlock Grid.Row="9" Text="Back camera" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <ComboBox Grid.Row="9" Grid.Column="1" x:Name="BackCameraBox" Margin="0,8,0,0" IsEditable="True" AutomationProperties.Name="Back camera">
                <ComboBoxItem>none</ComboBoxItem>
                <ComboBoxItem>emulated</ComboBoxItem>
                <ComboBoxItem>webcam0</ComboBoxItem>
            </ComboBox>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Click="Cancel_Click" IsCancel="True" AutomationProperties.Name="Cancel launch"/>
            <Button Content="Launch" Style="{StaticResource PrimaryButton}" Click="Launch_Click" Margin="10,0,0,0" IsDefault="True" AutomationProperties.Name="Launch emulator"/>
        </StackPanel>
    </StackPanel>
</Window>
