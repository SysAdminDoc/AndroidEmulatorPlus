<Window x:Class="AndroidEmulatorPlus.Views.SystemImagePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install system image"
        Width="640" Height="480"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource LavenderBrush}" Text="Install a system image"/>
        <TextBlock Grid.Row="0" Foreground="{StaticResource SubtextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,22,0,12">
            Pulled from `sdkmanager --list`. Pick one and click Install. The download is large (200-700 MB) and the disk install pulls several GB more.
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
            <TextBlock Text="Filter:" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
            <TextBox x:Name="FilterBox" Width="240" Margin="8,0,0,0" TextChanged="FilterBox_TextChanged"/>
            <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource FlatButton}" Margin="12,0,0,0" Click="Refresh_Click"/>
            <TextBlock x:Name="StatusText" Foreground="{StaticResource OverlayBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource CrustBrush}" CornerRadius="6">
            <ListBox x:Name="ImagesList" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="3" x:Name="ProgressText" Foreground="{StaticResource YellowBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="LicensesButton" Content="Accept all licenses" Style="{StaticResource FlatButton}" Click="Licenses_Click"/>
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Margin="10,0,0,0" Click="Cancel_Click" IsCancel="True"/>
            <Button x:Name="InstallButton" Content="Install" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Install_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
