<Window x:Class="AndroidEmulatorPlus.Views.SystemImagePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install system image"
        Width="640" Height="480"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource LavenderBrush}" Text="Install a system image"/>
            <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,12">
                Pulled from <Run FontFamily="Cascadia Mono">sdkmanager --list</Run>. Pick one and install. Downloads are large, and the extracted image can use several GB.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
            <TextBlock Text="Filter" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
            <TextBox x:Name="FilterBox" Width="240" Margin="8,0,0,0" TextChanged="FilterBox_TextChanged"
                     AutomationProperties.Name="Filter system images"/>
            <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource FlatButton}" Margin="12,0,0,0" Click="Refresh_Click"/>
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource OverlayBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" CornerRadius="6">
            <ListBox x:Name="ImagesList" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <ProgressBar x:Name="InstallProgressBar" Minimum="0" Maximum="100" Height="6"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="ProgressText" Foreground="{DynamicResource YellowBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="LicensesButton" Content="Accept all licenses" Style="{StaticResource FlatButton}" Click="Licenses_Click"/>
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Margin="10,0,0,0" Click="Cancel_Click" IsCancel="True"/>
            <Button x:Name="InstallButton" Content="Install" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Install_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
