<UserControl x:Class="AndroidEmulatorPlus.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource HeaderText}" Text="Console"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Sensor / GPS / battery / telephony / network simulation against a running emulator via <Run FontFamily="Cascadia Mono">adb emu</Run>. Use it for repeatable app-testing conditions without leaving this window.
            </TextBlock>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="GPS"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Latitude" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <TextBox  Grid.Column="1" Text="{Binding GpsLatitude}" AutomationProperties.Name="GPS latitude"/>
                        <TextBlock Grid.Column="2" Text="Longitude" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <TextBox  Grid.Column="3" Text="{Binding GpsLongitude}" AutomationProperties.Name="GPS longitude"/>
                    </Grid>
                    <Button Content="Set location" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Command="{Binding SetGeoCommand}" AutomationProperties.Name="Set GPS location"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Battery"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Capacity (%)" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding BatteryPercent}" VerticalAlignment="Center"
                                AutomationProperties.Name="Battery capacity percent"/>
                        <TextBlock Grid.Column="2" Text="{Binding BatteryPercent}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding PowerStates}" SelectedItem="{Binding PowerStatus}"
                                  AutomationProperties.Name="Battery status"/>
                    </Grid>
                    <Button Content="Apply battery state" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Command="{Binding SetBatteryCommand}" AutomationProperties.Name="Apply battery state"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Telephony"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Incoming call" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding GsmNumber}" FontFamily="Cascadia Mono" AutomationProperties.Name="Incoming call number"/>
                            <Button Grid.Column="1" Content="Ring" Style="{StaticResource FlatButton}" Margin="8,0,0,0" Command="{Binding RingCommand}" AutomationProperties.Name="Ring incoming call"/>
                        </Grid>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Incoming SMS" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                            <TextBox Text="{Binding SmsNumber}" FontFamily="Cascadia Mono" AutomationProperties.Name="Incoming SMS number"/>
                            <TextBox Text="{Binding SmsBody}" Margin="0,6,0,0" AutomationProperties.Name="Incoming SMS body"/>
                            <Button Content="Send SMS" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,8,0,0" Command="{Binding SendSmsCommand}" AutomationProperties.Name="Send incoming SMS"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Network condition"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Profile" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding NetworkProfiles}" SelectedItem="{Binding SelectedNetworkProfile}"
                                  AutomationProperties.Name="Network condition profile"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Speed preset" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Speeds}" SelectedItem="{Binding NetworkSpeed}"
                                  AutomationProperties.Name="Network speed preset"/>
                        <TextBlock Grid.Column="2" Text="Delay preset" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding Delays}" SelectedItem="{Binding NetworkDelay}"
                                  AutomationProperties.Name="Network delay preset"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0">
                        Pick a profile to auto-fill speed and delay, or choose individual values. Override profiles at <Run FontFamily="Cascadia Mono">%LOCALAPPDATA%\AndroidEmulatorPlus\presets\network-profiles.json</Run>.
                    </TextBlock>
                    <Button Content="Apply network" Style="{StaticResource FlatButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Command="{Binding SetNetworkCommand}" AutomationProperties.Name="Apply network condition"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Clipboard sync (manual)"/>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" TextWrapping="Wrap">
                        Manual round-trip to avoid the privacy cost of a background poll. Pull copies the emulator's primary clipboard into the host clipboard; Push goes the other way.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Pull from emulator" Style="{StaticResource FlatButton}" Command="{Binding PullClipboardCommand}" AutomationProperties.Name="Pull clipboard from emulator"/>
                        <Button Content="Push to emulator" Style="{StaticResource FlatButton}" Margin="8,0,0,0" Command="{Binding PushClipboardCommand}" AutomationProperties.Name="Push clipboard to emulator"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Sensors"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Accelerometer" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding AccelX}" Margin="0,0,4,0" AutomationProperties.Name="Accelerometer X"/>
                        <TextBox Grid.Column="2" Text="{Binding AccelY}" Margin="0,0,4,0" AutomationProperties.Name="Accelerometer Y"/>
                        <TextBox Grid.Column="3" Text="{Binding AccelZ}" Margin="0,0,4,0" AutomationProperties.Name="Accelerometer Z"/>
                        <Button Grid.Column="4" Content="Set" Style="{StaticResource FlatButton}" Command="{Binding SetAccelerometerCommand}" AutomationProperties.Name="Set accelerometer"/>

                        <TextBlock Grid.Row="1" Text="Gyroscope" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GyroX}" Margin="0,8,4,0" AutomationProperties.Name="Gyroscope X"/>
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding GyroY}" Margin="0,8,4,0" AutomationProperties.Name="Gyroscope Y"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding GyroZ}" Margin="0,8,4,0" AutomationProperties.Name="Gyroscope Z"/>
                        <Button Grid.Row="1" Grid.Column="4" Content="Set" Style="{StaticResource FlatButton}" Margin="0,8,0,0" Command="{Binding SetGyroscopeCommand}" AutomationProperties.Name="Set gyroscope"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                        Format: X:Y:Z. Accelerometer default is 0:9.8:0 (device upright). Gyroscope default is 0:0:0 (no rotation).
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Raw command"/>
                    <TextBlock Foreground="{DynamicResource OverlayBrush}" FontSize="11" TextWrapping="Wrap">
                        Sends arbitrary <Run FontFamily="Cascadia Mono">adb emu</Run> arguments. Examples: <Run FontFamily="Cascadia Mono">avd name</Run>, <Run FontFamily="Cascadia Mono">finger touch 1</Run>, <Run FontFamily="Cascadia Mono">rotate</Run>.
                    </TextBlock>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding FreeFormArgs, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono"
                                 AutomationProperties.Name="Raw emulator console command arguments"/>
                        <Button Grid.Column="1" Content="Send" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Command="{Binding SendFreeFormCommand}" AutomationProperties.Name="Send raw console command"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CrustBrush}" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                <TextBlock Text="{Binding LastResult}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" Foreground="{DynamicResource SubtextBrush}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
