<Window x:Class="AndroidEmulatorPlus.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="520" SizeToContent="Height"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Grid.Row="0"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource RedBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TextBlock x:Name="BodyText"
                   Grid.Row="1"
                   Foreground="{DynamicResource SubtextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <Border x:Name="DetailContainer"
                Grid.Row="2"
                Background="{DynamicResource CrustBrush}"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,12"
                Visibility="Collapsed"
                MaxHeight="180">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DetailText"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="11"
                           Foreground="{DynamicResource SubtextBrush}"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>
        </Border>

        <StackPanel x:Name="TypedConfirmPanel"
                    Grid.Row="3"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
            <TextBlock x:Name="TypedConfirmPrompt"
                       Foreground="{DynamicResource YellowBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TypedConfirmBox"
                     AutomationProperties.Name="Typed confirmation text"
                     TextChanged="TypedConfirmBox_TextChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource FlatButton}"
                    Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Confirm" Style="{StaticResource DangerButton}"
                    Click="OkButton_Click" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
