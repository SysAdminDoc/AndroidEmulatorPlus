<UserControl x:Class="AndroidEmulatorPlus.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Apps / Debloat"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Inventory of installed apps on the running emulator. Bulk-uninstall, batch-install APKs, or apply a debloat preset. Tip: drag <Run FontWeight="SemiBold">.apk</Run> / <Run FontWeight="SemiBold">.apks</Run> / <Run FontWeight="SemiBold">.xapk</Run> / <Run FontWeight="SemiBold">.apkm</Run> files anywhere on this tab to install them — bundles are auto-extracted before install.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Width="240" Margin="8,0,0,0"/>
                        <CheckBox Content="Include system" IsChecked="{Binding IncludeSystem}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Include disabled" IsChecked="{Binding IncludeDisabled}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Verify signatures" IsChecked="{Binding VerifySignaturesBeforeInstall}" Margin="12,0,0,0" VerticalAlignment="Center"
                                  ToolTip="apksigner verify --print-certs runs before each install (R-08)"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Compute sizes" Style="{StaticResource FlatButton}" Command="{Binding ComputeSizesCommand}" Margin="8,0,0,0" ToolTip="Root required: runs du -sb /data/data/&lt;pkg&gt; for each visible row"/>
                        <Button Content="Install APK…" Style="{StaticResource FlatButton}" Command="{Binding InstallApkCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
                <WrapPanel Margin="0,10,0,0">
                    <Button Content="Select all" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="Select none" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="0,0,8,0"/>
                    <ItemsControl ItemsSource="{Binding BloatPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}"
                                        ToolTip="{Binding Description}"
                                        Style="{StaticResource FlatButton}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"/>
                                <Border Grid.Column="1" Style="{StaticResource StatusPill}" Margin="6,2,0,0">
                                    <TextBlock Text="{Binding SourceTag}" FontSize="11" Foreground="{StaticResource MauveBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="{StaticResource OverlayBrush}" FontFamily="Cascadia Mono" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="60" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Action mode:" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                <RadioButton GroupName="UninstallMode" Content="Uninstall (adb)" Margin="10,0,0,0"
                             IsChecked="{Binding UninstallMode, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=user, Mode=OneWay}"
                             Command="{Binding SetUninstallModeUserCommand}" />
                <RadioButton GroupName="UninstallMode" Content="Disable for user 0 (reversible)" Margin="14,0,0,0"
                             IsChecked="{Binding UninstallMode, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=user0, Mode=OneWay}"
                             Command="{Binding SetUninstallModeUser0Command}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="✗ Uninstall Selected" Style="{StaticResource DangerButton}" Command="{Binding UninstallSelectedCommand}"/>
                <Button Content="↺ Re-enable selected (user 0)" Style="{StaticResource FlatButton}" Command="{Binding ReinstallSelectedCommand}" Margin="8,0,0,0"
                        ToolTip="cmd package install-existing — only useful for apps removed via 'Disable for user 0'."/>
                <Button Content="⤓ Export data…" Style="{StaticResource FlatButton}" Command="{Binding ExportSelectedCommand}" Margin="8,0,0,0"
                        ToolTip="Tar /data/data/&lt;pkg&gt; per selected app into a .zip (root required)."/>
                <Button Content="⤒ Import from ZIP…" Style="{StaticResource FlatButton}" Command="{Binding ImportZipCommand}" Margin="8,0,0,0"
                        ToolTip="Restore a .zip produced by Export data into /data/data/&lt;pkg&gt; (root required, package must be installed)."/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
