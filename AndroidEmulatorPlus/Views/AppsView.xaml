<UserControl x:Class="AndroidEmulatorPlus.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Apps / Debloat"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Inventory of installed apps on the running emulator. Bulk-uninstall, batch-install APKs, or apply a debloat preset.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Width="240" Margin="8,0,0,0"/>
                        <CheckBox Content="Include system" IsChecked="{Binding IncludeSystem}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Install APK…" Style="{StaticResource FlatButton}" Command="{Binding InstallApkCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
                <WrapPanel Margin="0,10,0,0">
                    <Button Content="Select all" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="Select none" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="0,0,8,0"/>
                    <Button Content="Preset: Google bloat" Style="{StaticResource FlatButton}" Command="{Binding SelectGoogleBloatCommand}" Margin="0,0,8,0"/>
                    <Button Content="Preset: Samsung bloat" Style="{StaticResource FlatButton}" Command="{Binding SelectSamsungBloatCommand}" Margin="0,0,8,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SizeText}" Foreground="{StaticResource OverlayBrush}" FontFamily="Cascadia Mono" FontSize="11" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="✗ Uninstall Selected" Style="{StaticResource DangerButton}" Command="{Binding UninstallSelectedCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
