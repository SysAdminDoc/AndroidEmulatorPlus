<UserControl x:Class="AndroidEmulatorPlus.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views"
             AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="Apps / Debloat"/>
            <TextBlock Style="{StaticResource SubheaderText}" TextWrapping="Wrap">
                Inventory of installed apps on the running emulator. Bulk-uninstall, batch-install APKs, or apply a debloat preset. Tip: drag <Run FontWeight="SemiBold">.apk</Run> / <Run FontWeight="SemiBold">.apks</Run> / <Run FontWeight="SemiBold">.xapk</Run> / <Run FontWeight="SemiBold">.apkm</Run> files anywhere on this tab to install them; bundles are auto-extracted before install.
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Inventory controls"/>
                <WrapPanel Margin="0,0,-10,-8">
                    <StackPanel Width="260" Margin="0,0,12,8">
                        <TextBlock Text="Filter packages" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Filter installed packages"/>
                    </StackPanel>
                    <CheckBox Content="Include system apps" IsChecked="{Binding IncludeSystem}" Margin="0,20,14,8" VerticalAlignment="Center"
                              AutomationProperties.Name="Include system apps"/>
                    <CheckBox Content="Include disabled apps" IsChecked="{Binding IncludeDisabled}" Margin="0,20,14,8" VerticalAlignment="Center"
                              AutomationProperties.Name="Include disabled apps"/>
                    <CheckBox Content="Verify signatures before install" IsChecked="{Binding VerifySignaturesBeforeInstall}" Margin="0,20,14,8" VerticalAlignment="Center"
                              ToolTip="Runs apksigner verify --print-certs before each install."
                              AutomationProperties.Name="Verify signatures before install"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,-8,-8">
                    <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" Margin="0,0,8,8"
                            AutomationProperties.Name="Refresh"/>
                    <Button Content="Compute sizes" Style="{StaticResource FlatButton}" Command="{Binding ComputeSizesCommand}" Margin="0,0,8,8"
                            ToolTip="Root required: runs du -sb /data/data/&lt;pkg&gt; for every loaded row"
                            AutomationProperties.Name="Compute sizes"/>
                    <Button Content="Install APK..." Style="{StaticResource FlatButton}" Command="{Binding InstallApkCommand}" Margin="0,0,8,8"
                            AutomationProperties.Name="Install APK"/>
                    <Button Content="Select all" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" Margin="0,0,8,8"
                            AutomationProperties.Name="Select all"/>
                    <Button Content="Select none" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" Margin="0,0,8,8"
                            AutomationProperties.Name="Select none"/>
                    <ItemsControl ItemsSource="{Binding BloatPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}"
                                        ToolTip="{Binding Description}"
                                        Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.Name="{Binding Name}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420"
                            Visibility="{Binding HasApps, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="No apps loaded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource MicrocopyText}" TextAlignment="Center" Margin="0,6,0,0"
                               Text="Start an emulator, then refresh this tab to load installed packages."/>
                    <Button Content="Refresh apps" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" HorizontalAlignment="Center" Margin="0,12,0,0"
                            AutomationProperties.Name="Refresh apps"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420"
                            Visibility="{Binding IsFilteredEmpty, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="No apps match this filter" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource MicrocopyText}" TextAlignment="Center" Margin="0,6,0,0"
                               Text="Clear or broaden the filter to see the loaded package list."/>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasFilteredApps, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                    <ItemsControl ItemsSource="{Binding FilteredApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CrustBrush}" BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="9,7" Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Package}"
                                              AutomationProperties.Name="{Binding Package}"/>
                                    <Border Grid.Column="1" Style="{StaticResource StatusPill}" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding SourceTag}" FontSize="11" Foreground="{DynamicResource MauveBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="{DynamicResource OverlayBrush}" FontFamily="Cascadia Mono" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="60" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Selected app actions"/>
                <WrapPanel Margin="0,0,-14,-8">
                    <TextBlock Text="Removal mode" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,4,10,8"/>
                    <RadioButton GroupName="UninstallMode" Content="Uninstall with adb" Margin="0,2,14,8"
                                 IsChecked="{Binding UninstallMode, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=user, Mode=OneWay}"
                                 Command="{Binding SetUninstallModeUserCommand}"
                                 AutomationProperties.Name="Uninstall with adb"/>
                    <RadioButton GroupName="UninstallMode" Content="Disable for user 0 (reversible)" Margin="0,2,14,8"
                                 IsChecked="{Binding UninstallMode, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=user0, Mode=OneWay}"
                                 Command="{Binding SetUninstallModeUser0Command}"
                                 AutomationProperties.Name="Disable for user 0 (reversible)"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,-8,-8">
                    <Button Content="Uninstall selected" Style="{StaticResource DangerButton}" Command="{Binding UninstallSelectedCommand}" Margin="0,0,8,8"
                            AutomationProperties.Name="Uninstall selected"/>
                    <Button Content="Re-enable selected" Style="{StaticResource FlatButton}" Command="{Binding ReinstallSelectedCommand}" Margin="0,0,8,8"
                            ToolTip="Runs cmd package install-existing. Use for apps removed with Disable for user 0."
                            AutomationProperties.Name="Re-enable selected"/>
                    <Button Content="Export data..." Style="{StaticResource FlatButton}" Command="{Binding ExportSelectedCommand}" Margin="0,0,8,8"
                            ToolTip="Tar /data/data/&lt;pkg&gt; per selected app into a .zip. Root required."
                            AutomationProperties.Name="Export data"/>
                    <Button Content="Import ZIP..." Style="{StaticResource FlatButton}" Command="{Binding ImportZipCommand}" Margin="0,0,8,8"
                            ToolTip="Restore a .zip produced by Export data. Root required and package must be installed."
                            AutomationProperties.Name="Import ZIP"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
