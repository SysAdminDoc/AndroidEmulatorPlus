<UserControl x:Class="AndroidEmulatorPlus.Views.AvdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="AVDs"/>
            <TextBlock Style="{StaticResource SubheaderText}" Text="Launch, edit, or delete Android Virtual Devices. Create new ones from system images installed on this machine."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding HasAvds, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="No AVDs yet"/>
                        <TextBlock Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap">
                            Create one using the form below. If the System image dropdown is empty, install a system image from the Install / SDK tab first (or use Android Studio's SDK Manager).
                        </TextBlock>
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding Avds}"
                              Visibility="{Binding HasAvds, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <Border Style="{StaticResource StatusPill}" Margin="10,2,0,0">
                                            <TextBlock Text="{Binding Badge}" FontSize="11" Foreground="{StaticResource MauveBrush}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusPill}" Margin="6,2,0,0" Background="{StaticResource GreenBrush}"
                                                Visibility="{Binding IsRunning, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="● Running" FontSize="11" Foreground="{StaticResource CrustBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource SubtextBrush}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding SystemImage}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="{StaticResource OverlayBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="▶ Launch" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsRunning, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}"/>
                                    <Button Content="■ Stop" Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsRunning, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"/>
                                    <Button Content="Cold Boot" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                                            Command="{Binding DataContext.LaunchColdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Style="{StaticResource FlatButton}" Margin="8,0,0,0" Padding="10,8"
                                            Click="OverflowButton_Click" Content="⋯">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Launch with options…"
                                                          Command="{Binding DataContext.LaunchWithOptionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Show on disk"
                                                          Command="{Binding DataContext.ShowOnDiskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Rename…"
                                                          Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Duplicate…"
                                                          Command="{Binding DataContext.DuplicateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Snapshots…"
                                                          Command="{Binding DataContext.ManageSnapshotsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Create desktop shortcut"
                                                          Command="{Binding DataContext.CreateShortcutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Delete AVD…"
                                                          Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Create new AVD"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Name" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="Device profile" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedItem="{Binding NewDevice}" IsEditable="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="System image" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <Button Grid.Column="1" Content="Browse online…" Style="{StaticResource FlatButton}"
                                    MinWidth="0" Padding="8,2" MinHeight="0"
                                    Command="{Binding BrowseSystemImagesCommand}"
                                    ToolTip="sdkmanager --list, then install a new system image"/>
                        </Grid>
                        <ComboBox ItemsSource="{Binding AvailableImages}" SelectedItem="{Binding NewImage}"/>
                    </StackPanel>
                    <Button Grid.Column="3" Content="Create" Style="{StaticResource PrimaryButton}" Margin="12,18,0,0"
                            Command="{Binding CreateCommand}" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
