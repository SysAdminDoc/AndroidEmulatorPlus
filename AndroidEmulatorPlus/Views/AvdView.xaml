<UserControl x:Class="AndroidEmulatorPlus.Views.AvdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AndroidEmulatorPlus.Views">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeaderText}" Text="AVDs"/>
            <TextBlock Style="{StaticResource SubheaderText}" Text="Launch, edit, or delete Android Virtual Devices. Create new ones from system images installed on this machine."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Refresh" Style="{StaticResource FlatButton}" Command="{Binding RefreshCommand}" AutomationProperties.Name="Refresh AVDs list"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding HasAvds, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource LavenderBrush}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="No AVDs yet. Create one below, or install a system image first if the list is empty."/>
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding Avds}"
                              Visibility="{Binding HasAvds, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                        <Border Style="{StaticResource StatusPill}" Margin="10,2,0,0">
                                            <TextBlock Text="{Binding Badge}" FontSize="11" Foreground="{DynamicResource MauveBrush}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusPill}" Margin="6,2,0,0" Background="{DynamicResource GreenBrush}"
                                                Visibility="{Binding IsRunning, Converter={x:Static views:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="Running" FontSize="11" Foreground="{DynamicResource CrustBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource SubtextBrush}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding SystemImage}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="{DynamicResource OverlayBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Launch" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsRunning, Converter={x:Static views:NotBoolToVisibilityConverter.Instance}}"
                                            AutomationProperties.Name="Launch AVD"/>
                                    <Button Content="Stop" Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsRunning, Converter={x:Static views:BoolToVisibilityConverter.Instance}}"
                                            AutomationProperties.Name="Stop running AVD"/>
                                    <Button Content="Cold Boot" Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                                            Command="{Binding DataContext.LaunchColdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="Cold boot AVD"/>
                                    <Button Style="{StaticResource SmallButton}" Margin="8,0,0,0" Padding="10,8"
                                            AutomationProperties.Name="Open AVD actions"
                                            ToolTip="Show actions for this AVD"
                                            Click="OverflowButton_Click" Content="...">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Launch with options..."
                                                          Command="{Binding DataContext.LaunchWithOptionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Show on disk"
                                                          Command="{Binding DataContext.ShowOnDiskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Rename..."
                                                          Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Duplicate..."
                                                          Command="{Binding DataContext.DuplicateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Snapshots..."
                                                          Command="{Binding DataContext.ManageSnapshotsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Create desktop shortcut"
                                                          Command="{Binding DataContext.CreateShortcutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Delete AVD..."
                                                          Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Create new AVD"/>
                <StackPanel>
                    <StackPanel>
                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="New AVD name"/>
                    </StackPanel>
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Device profile" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedItem="{Binding NewDevice}" IsEditable="True"
                                  AutomationProperties.Name="Device profile"/>
                    </StackPanel>
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="System image" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableImages}" SelectedItem="{Binding NewImage}"
                                  AutomationProperties.Name="System image"/>
                    </StackPanel>
                    <WrapPanel Margin="0,12,-8,-8">
                        <Button Content="Browse online..." Style="{StaticResource FlatButton}" Margin="0,0,8,8"
                                Command="{Binding BrowseSystemImagesCommand}"
                                ToolTip="sdkmanager --list, then install a new system image"
                                AutomationProperties.Name="Browse system images online"/>
                        <Button Content="Create" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                Command="{Binding CreateCommand}"
                                AutomationProperties.Name="Create new AVD"/>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
