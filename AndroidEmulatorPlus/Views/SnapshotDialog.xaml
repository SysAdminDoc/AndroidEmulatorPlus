<Window x:Class="AndroidEmulatorPlus.Views.SnapshotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapshots"
        Width="600" Height="460"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource LavenderBrush}"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource SubtextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,10">
            Snapshots live under <Run FontFamily="Cascadia Mono">&lt;avd&gt;.avd/snapshots/</Run>. Save / Load require the emulator to be running; Delete works any time.
        </TextBlock>

        <Border Grid.Row="2" Background="{DynamicResource CrustBrush}" CornerRadius="6">
            <ListBox x:Name="List" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Snapshots list">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText" Foreground="{DynamicResource YellowBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="New snapshot" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="SaveNameBox" Width="180" Margin="0,0,8,0" Text="my-snapshot"
                     AutomationProperties.Name="New snapshot name"
                     ToolTip="Name to save the running emulator state under"/>
            <Button Content="Save" Style="{StaticResource FlatButton}" Click="Save_Click" AutomationProperties.Name="Save snapshot"/>
            <Button Content="Load" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Load_Click" AutomationProperties.Name="Load snapshot"/>
            <Button Content="Delete" Style="{StaticResource DangerButton}" Margin="10,0,0,0" Click="Delete_Click" AutomationProperties.Name="Delete snapshot"/>
            <Button Content="Close" Style="{StaticResource FlatButton}" Margin="10,0,0,0" Click="Close_Click" IsCancel="True" AutomationProperties.Name="Close snapshots dialog"/>
        </StackPanel>
    </Grid>
</Window>
